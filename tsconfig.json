{
  "compilerOptions": {
    "target": "ES2021",
    "module": "preserve",
    "lib": ["ES2021", "DOM"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": ["tests", "pages", "fixtures", "config", "playwright.config.ts"],
  "exclude": ["node_modules"]
}
